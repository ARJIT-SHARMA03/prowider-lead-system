// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Service {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  leads     Lead[]
  createdAt DateTime @default(now())

  @@map("services")
}

model Provider {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  monthlyQuota    Int              @default(10)
  currentMonthLeads Int            @default(0)
  // Round-robin index: tracks how many times this provider was picked from fair pool
  fairPickCount   Int              @default(0)
  createdAt       DateTime         @default(now())
  leadAssignments LeadAssignment[]

  @@map("providers")
}

model Lead {
  id          Int              @id @default(autoincrement())
  name        String
  phone       String
  city        String
  description String
  serviceId   Int
  service     Service          @relation(fields: [serviceId], references: [id])
  assignments LeadAssignment[]
  createdAt   DateTime         @default(now())

  // Duplicate prevention: same phone + same service not allowed
  @@unique([phone, serviceId])
  @@map("leads")
}

model LeadAssignment {
  id         Int      @id @default(autoincrement())
  leadId     Int
  providerId Int
  lead       Lead     @relation(fields: [leadId], references: [id])
  provider   Provider @relation(fields: [providerId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([leadId, providerId])
  @@map("lead_assignments")
}

// Tracks idempotency keys for webhook calls
model WebhookEvent {
  id             Int      @id @default(autoincrement())
  idempotencyKey String   @unique
  processedAt    DateTime @default(now())
  payload        Json

  @@map("webhook_events")
}
