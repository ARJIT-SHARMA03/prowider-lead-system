# .env.example — copy to .env.local and fill in your values

# PostgreSQL connection string
# Local:   postgresql://postgres:password@localhost:5432/prowider
# Neon:    postgresql://user:pass@ep-xxx.neon.tech/prowider?sslmode=require
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/prowider"

# Webhook shared secret — set to any random string
WEBHOOK_SECRET="dev-secret"

# Optional: expose secret to browser for test-tools page
# (only for dev — do NOT expose real secrets in production)
NEXT_PUBLIC_WEBHOOK_SECRET="dev-secret"
